# Railway automatski postavlja DATABASE_URL kad dodaš PostgreSQL servis
DATABASE_URL=postgres://user:pass@host:5432/alfaplast
# Ako baza traži SSL (Railway obično da):
PGSSL=true
# Obavezno promijeni u dugi nasumični string!
JWT_SECRET=promijeni-me
# Fotografije — na Railwayu montiraj Volume na /data
UPLOAD_DIR=/data/uploads
# Podsjetnik za zadatke u statusu "primljeno" (sati)
REMINDER_HOURS=24
# Koliko dana prije montaže se kreira podsjetnik u to-do listi
JOB_REMINDER_DAYS=3
PORT=3000
# Push obavijesti (Web Push) — generiraj vlastite s: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@alfaplast.hr
